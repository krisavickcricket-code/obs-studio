IDI_ICON1 ICON DISCARDABLE "cmake/windows/obs-studio.ico"

1 VERSIONINFO
FILEVERSION ${OBS_VERSION_MAJOR},${OBS_VERSION_MINOR},${OBS_VERSION_PATCH},0
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "CricNode"
      VALUE "FileDescription", "CricNode PC Recorder"
      VALUE "FileVersion", "${OBS_VERSION_CANONICAL}"
      VALUE "InternalName", "CricNodePCRecorder"
      VALUE "OriginalFilename", "obs64.exe"
      VALUE "ProductName", "CricNode PC Recorder"
      VALUE "ProductVersion", "${OBS_VERSION_CANONICAL}"
      VALUE "Comments", "Cricket video recording software by CricNode"
      VALUE "LegalCopyright", "${OBS_LEGAL_COPYRIGHT}"
    END
  END

  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 0x04B0
  END
END
